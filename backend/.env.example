# WikiBot Backend Configuration
# Copy this file to .env and fill in your actual values

# JWT Configuration
JWT_SECRET_KEY=your-secret-key-here-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database
DATABASE_URL=sqlite:///./data/wikibot.db

# ChromaDB
CHROMA_DB_PATH=./chroma_db

# LLM Model Configuration
# Download a GGUF model and set the path here
# Recommended models for 8GB RAM:
# - Qwen2.5-3B-Instruct-Q4_K_M.gguf (~2GB)
# - Llama-3.2-3B-Instruct-Q4_K_M.gguf (~2GB)
MODEL_PATH=./llm_models/qwen2.5-3b-instruct-q4_k_m.gguf
MODEL_CONTEXT_LENGTH=4096
MODEL_TEMPERATURE=0.7
MODEL_MAX_TOKENS=2048

# Embedding Model
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# File Storage
DATA_DIR=./data
MAX_FILE_SIZE=50

# Logging
LOG_LEVEL=INFO
